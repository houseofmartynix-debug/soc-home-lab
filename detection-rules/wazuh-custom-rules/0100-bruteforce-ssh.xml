<!--
  Rule:     SSH Brute Force Detection
  ID:       100100 (group), 100101 (single alert)
  Author:   SOC Home Lab
  MITRE:    T1110.001 — Brute Force: Password Guessing
  Severity: 10 (high)

  Intent:
    Wazuh already ships rule 5712 (sshd: Possible attack — 8 fails in 120s).
    This rule extends that by:
      - tagging the alert with MITRE technique ID
      - raising severity once the source IP has tripped the threshold
      - capturing source IP into a custom field for SOAR enrichment

  FP:
    - Forgotten password from legitimate user inside the LAN
    - Automated config-management tool with stale SSH key
  Tuning:
    - Whitelist known jump-host IPs with rule 100199 (negate)
-->

<group name="ssh,authentication_failures,attack,">

  <rule id="100100" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5712</if_matched_sid>
    <description>SSH brute force attack — 8+ failed logins in 120s from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <rule id="100101" level="12" frequency="15" timeframe="300">
    <if_matched_sid>100100</if_matched_sid>
    <description>SSH brute force — sustained attack from $(srcip), block recommended</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failed,attack,</group>
  </rule>

</group>
